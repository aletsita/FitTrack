<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    tools:context=".ui.dashboard.DashboardFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="36dp">

            <!-- ====================================================== -->
            <!-- ENCABEZADO -->
            <!-- ====================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/fondo_encabezado_dashboard"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="36dp"
                android:paddingEnd="24dp"
                android:paddingBottom="48dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fondo_chip_translucido"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_fitness"
                                app:tint="#A8E0C1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:letterSpacing="0.15"
                                android:text="FITTRACK"
                                android:textColor="#A8E0C1"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSaludo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            tools:text="¡Hola, Alexa!" />

                        <TextView
                            android:id="@+id/tvRolUsuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Administrador de FitTrack"
                            android:textColor="#C7E8D5"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Avatar con anillo -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <TextView
                            android:id="@+id/btnAvatarPerfil"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:background="@drawable/fondo_icono_verde"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="A"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/fondo_punto_online" />

                    </FrameLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMensajeDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:lineSpacingMultiplier="1.25"
                    android:text="El gimnasio está activo. Revisa el rendimiento de tus atletas y organiza los entrenamientos."
                    android:textColor="#E8F5EE"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ====================================================== -->
            <!-- CONTENIDO CON DESPLAZAMIENTO NEGATIVO -->
            <!-- ====================================================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- TARJETA EN VIVO (Héroe) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEntrenamientoHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#1A232C"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/fondo_card_vivo"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.1"
                                android:text="ACTIVIDAD DE HOY"
                                android:textColor="#9FD7B8"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/fondo_icono_verde"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="8dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/fondo_punto_online" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="EN VIVO"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/fondo_icono_verde"
                                android:contentDescription="Entrenamientos"
                                android:padding="14dp"
                                android:src="@drawable/ic_fitness"
                                app:tint="#FFFFFF" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvNumeroEntrenamientos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12"
                                    android:textColor="#FFFFFF"
                                    android:textSize="36sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvEntrenamientosHoy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="sesiones programadas"
                                    android:textColor="#B0BEC5"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="18dp"
                            android:background="#2E3A46" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mantén al equipo en movimiento"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.05"
                                android:text="FITTRACK TEAM"
                                android:textColor="#9FD7B8"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================================================== -->
                <!-- SECCIÓN: RESUMEN DEL GIMNASIO -->
                <!-- ================================================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resumen del gym"
                            android:textColor="#F1F5F9"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Rendimiento general de FitTrack"
                            android:textColor="#8B98A5"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/fondo_chip_hoy"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="HOY"
                        android:textColor="#4ADE80"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- METRICAS: FILA 1 (Clientes y Rutinas) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardClientes"
                        android:layout_width="0dp"
                        android:layout_height="164dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#161B22"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#232B34"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@drawable/fondo_icono_azul_tonal"
                                android:contentDescription="Clientes"
                                android:padding="10dp"
                                android:src="@drawable/ic_people"
                                app:tint="#5B9BF2" />

                            <Space
                                android:layout_width="1dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvTotalClientes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="48"
                                android:textColor="#F1F5F9"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Atletas activos"
                                android:textColor="#8B98A5"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRutinas"
                        android:layout_width="0dp"
                        android:layout_height="164dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#238B57"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/fondo_card_verde_degradado"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@drawable/fondo_icono_blanco_tonal"
                                android:contentDescription="Rutinas"
                                android:padding="10dp"
                                android:src="@drawable/ic_routine"
                                app:tint="#FFFFFF" />

                            <Space
                                android:layout_width="1dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvTotalRutinas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="15"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rutinas activas"
                                android:textColor="#E8F5EE"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- METRICAS: FILA 2 (Coaches y Progreso) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardEntrenadores"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#1A232C"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@drawable/fondo_icono_morado_tonal"
                                android:contentDescription="Entrenadores"
                                android:padding="10dp"
                                android:src="@drawable/ic_trainer"
                                app:tint="#5B9BF2" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvTotalEntrenadores"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8"
                                    android:textColor="#FFFFFF"
                                    android:textSize="24sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Coaches"
                                    android:textColor="#B0BEC5"
                                    android:textSize="12sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardProgreso"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#161B22"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#232B34"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:background="@drawable/fondo_icono_rojo_tonal"
                                    android:contentDescription="Progreso"
                                    android:padding="7dp"
                                    android:src="@drawable/ic_fitness"
                                    app:tint="#2FA968" />

                                <TextView
                                    android:id="@+id/tvProgresoPromedio"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:layout_weight="1"
                                    android:gravity="end"
                                    android:text="78%"
                                    android:textColor="#F1F5F9"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Progreso promedio"
                                android:textColor="#8B98A5"
                                android:textSize="12sp" />

                            <ProgressBar
                                android:id="@+id/progressBarProgreso"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginTop="8dp"
                                android:max="100"
                                android:progress="78"
                                android:progressDrawable="@drawable/fondo_barra_progreso" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ================================================== -->
                <!-- SECCIÓN: ACCIONES RÁPIDAS -->
                <!-- ================================================== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="¿Qué quieres hacer?"
                    android:textColor="#F1F5F9"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Accede rápidamente a las herramientas del gimnasio"
                    android:textColor="#8B98A5"
                    android:textSize="13sp" />

                <!-- BOTÓN: CLIENTES -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnVerClientes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#232B34"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="40dp"
                            android:background="@drawable/fondo_barra_acento_azul" />

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="14dp"
                            android:background="@drawable/fondo_icono_azul_tonal"
                            android:contentDescription="Clientes"
                            android:padding="12dp"
                            android:src="@drawable/ic_people"
                            app:tint="#5B9BF2" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mis atletas"
                                android:textColor="#F1F5F9"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Consulta clientes y su información"
                                android:textColor="#8B98A5"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/fondo_circulo_flecha"
                            android:contentDescription="Abrir"
                            android:padding="8dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#4ADE80" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BOTÓN: RUTINAS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnVerRutinas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#232B34"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="40dp"
                            android:background="@drawable/fondo_barra_acento_naranja" />

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="14dp"
                            android:background="@drawable/fondo_icono_naranja_tonal"
                            android:contentDescription="Rutinas"
                            android:padding="12dp"
                            android:src="@drawable/ic_routine"
                            app:tint="#2FA968" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Zona de entrenamiento"
                                android:textColor="#F1F5F9"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Gestiona planes y rutinas de ejercicio"
                                android:textColor="#8B98A5"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/fondo_circulo_flecha"
                            android:contentDescription="Abrir"
                            android:padding="8dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#4ADE80" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>