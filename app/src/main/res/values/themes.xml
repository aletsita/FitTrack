<?xml version="1.0" encoding="utf-8"?>

<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- TEMA BASE DE FITTRACK -->

    <style
        name="Base.Theme.Proyecto"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Color principal de FitTrack -->
        <item name="colorPrimary">#238B57</item>

        <!-- Color del contenido sobre el color principal -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Color secundario -->
        <item name="colorSecondary">#238B57</item>

        <!-- Fondo del indicador seleccionado del BottomNavigation -->
        <item name="colorSecondaryContainer">#FFFFFF</item>

        <!-- Color del contenido seleccionado -->
        <item name="colorOnSecondaryContainer">#238B57</item>

        <!-- Fondo general de la aplicación -->
        <item name="android:windowBackground">#F4F6F8</item>

        <!-- Barra inferior del sistema Android -->
        <item name="android:navigationBarColor">#FFFFFF</item>

        <!-- Iconos oscuros en la barra inferior del sistema -->
        <item name="android:windowLightNavigationBar">true</item>

    </style>


    <!-- TEMA PRINCIPAL DE LA APLICACIÓN -->

    <style
        name="Theme.Proyecto"
        parent="Base.Theme.Proyecto" />


    <!-- TEXTO ACTIVO DEL MENÚ INFERIOR -->

    <style name="FitTrackBottomNavigationTextActive">

        <item name="android:textSize">10sp</item>

        <item name="android:textStyle">bold</item>

        <item name="android:fontFamily">sans</item>

    </style>


    <!-- TEXTO INACTIVO DEL MENÚ INFERIOR -->

    <style name="FitTrackBottomNavigationTextInactive">

        <item name="android:textSize">10sp</item>

        <item name="android:textStyle">normal</item>

        <item name="android:fontFamily">sans</item>

    </style>

</resources>