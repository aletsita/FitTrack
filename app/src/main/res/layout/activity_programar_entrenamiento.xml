<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="35dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.15"
                android:text="CALENDARIO"
                android:textColor="#2F7BFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Programa tu entrenamiento"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Elige una rutina, fecha y ejercicios para crear tu sesión."
                android:textColor="#B7C0CD"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- INFORMACIÓN -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información general"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="18dp"
                android:text="Configura los datos principales de la sesión."
                android:textColor="#8D99A8"
                android:textSize="13sp"/>

            <!-- RUTINA -->

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Rutina"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <AutoCompleteTextView
                    android:id="@+id/actvRutinaProgramada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8D99A8"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- OBJETIVO -->

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Objetivo del entrenamiento"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <AutoCompleteTextView
                    android:id="@+id/actvObjetivoEntrenamiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8D99A8"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- FECHA Y HORA -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="Fecha"
                    app:boxBackgroundColor="#151B26"
                    app:boxStrokeColor="#2F7BFF"
                    app:hintTextColor="#8D99A8"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusBottomEnd="18dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFechaProgramada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:hint="Seleccionar"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8D99A8"/>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:hint="Hora"
                    app:boxBackgroundColor="#151B26"
                    app:boxStrokeColor="#2F7BFF"
                    app:hintTextColor="#8D99A8"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusBottomEnd="18dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHoraProgramada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:hint="Seleccionar"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#8D99A8"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ================= EJERCICIOS ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ejercicios"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Agrega los ejercicios en el orden que realizarás."
                        android:textColor="#8D99A8"
                        android:textSize="13sp"/>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgregarEjercicio"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Agregar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#2F7BFF"
                    app:cornerRadius="18dp"
                    app:elevation="4dp"/>

            </LinearLayout>

            <!-- MENSAJE SIN EJERCICIOS -->

            <TextView
                android:id="@+id/tvSinEjerciciosProgramados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/edittext_dark"
                android:gravity="center"
                android:padding="24dp"
                android:text="Todavía no has agregado ejercicios."
                android:textColor="#8D99A8"
                android:textSize="14sp"/>

            <!-- LISTA -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEjerciciosProgramados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_ejercicio_programado"/>

            <!-- ================= RESUMEN ================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#151B26"
                app:cardCornerRadius="22dp"
                app:cardElevation="5dp"
                app:strokeColor="#263242"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESUMEN DE LA SESIÓN"
                        android:textColor="#2F7BFF"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <!-- EJERCICIOS -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvResumenCantidadEjercicios"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EJERCICIOS"
                                android:textColor="#8D99A8"
                                android:textSize="10sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- SERIES -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvResumenSeries"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SERIES"
                                android:textColor="#8D99A8"
                                android:textSize="10sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- DURACIÓN -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvResumenDuracion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 min"
                                android:textColor="#2F7BFF"
                                android:textSize="24sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ESTIMADO"
                                android:textColor="#8D99A8"
                                android:textSize="10sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- BOTÓN PROGRAMAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarEntrenamientoProgramado"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                android:text="Programar entrenamiento"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2F7BFF"
                app:cornerRadius="22dp"
                app:elevation="5dp"/>

            <!-- BOTÓN CANCELAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarEntrenamientoProgramado"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="24dp"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#2F7BFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#151B26"
                app:cornerRadius="22dp"
                app:strokeColor="#2F7BFF"
                app:strokeWidth="1dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>