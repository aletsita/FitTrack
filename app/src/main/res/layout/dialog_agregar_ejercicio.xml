<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#070B12"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloDialogEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar ejercicio"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:text="Configura las series, repeticiones y descanso."
            android:textColor="#8D99A8"
            android:textSize="14sp"/>

        <!-- NOMBRE -->

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del ejercicio"
            app:boxBackgroundColor="#151B26"
            app:boxStrokeColor="#2F7BFF"
            app:hintTextColor="#8D99A8"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombreEjercicioDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#8D99A8"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- SERIES Y REPETICIONES -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Series"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSeriesEjercicioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Repeticiones"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRepeticionesEjercicioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"/>

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- PESO Y DESCANSO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Peso"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:suffixText="kg"
                app:suffixTextColor="#2F7BFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPesoEjercicioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"/>

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Descanso"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:suffixText="s"
                app:suffixTextColor="#2F7BFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescansoEjercicioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"/>

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- NOTAS -->

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Notas opcionales"
            app:boxBackgroundColor="#151B26"
            app:boxStrokeColor="#2F7BFF"
            app:hintTextColor="#8D99A8"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotasEjercicioDialog"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingTop="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#8D99A8"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTÓN GUARDAR -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarEjercicioDialog"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="28dp"
            android:text="Guardar ejercicio"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#2F7BFF"
            app:cornerRadius="22dp"
            app:elevation="5dp"/>

        <!-- BOTÓN CANCELAR -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarEjercicioDialog"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#2F7BFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#151B26"
            app:cornerRadius="22dp"
            app:strokeColor="#2F7BFF"
            app:strokeWidth="1dp"/>

    </LinearLayout>

</ScrollView>