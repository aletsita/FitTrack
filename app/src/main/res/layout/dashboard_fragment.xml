<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12"
    tools:context=".ui.dashboard.DashboardFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="36dp">

            <!-- ===================== HEADER ===================== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="270dp"
                android:background="@drawable/fondo_encabezado_dashboard"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="36dp"
                android:paddingEnd="24dp"
                android:paddingBottom="48dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.15"
                            android:text="FITTRACK"
                            android:textColor="#2F7BFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvSaludo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            tools:text="¡Hola, Alexa!"/>

                        <TextView
                            android:id="@+id/tvRolUsuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Administrador de FitTrack"
                            android:textColor="#B7C0CD"
                            android:textSize="14sp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnAvatarPerfil"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/fondo_icono_azul"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="A"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMensajeDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingMultiplier="1.2"
                    android:text="El gimnasio está activo. Revisa el rendimiento de tus atletas y organiza los entrenamientos."
                    android:textColor="#B7C0CD"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- CONTENIDO -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- ================= TARJETA PRINCIPAL ================= -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEntrenamientoHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#151B26"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#263242"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:letterSpacing="0.12"
                                android:text="ACTIVIDAD DE HOY"
                                android:textColor="#2F7BFF"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/fondo_icono_azul"
                                android:paddingStart="12dp"
                                android:paddingTop="5dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="5dp"
                                android:text="EN VIVO"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:background="@drawable/fondo_icono_azul"
                                android:contentDescription="Entrenamientos"
                                android:padding="16dp"
                                android:src="@drawable/ic_fitness"
                                app:tint="#FFFFFF"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvNumeroEntrenamientos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12"
                                    android:textColor="#FFFFFF"
                                    android:textSize="38sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvEntrenamientosHoy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="Sesiones programadas"
                                    android:textColor="#8D99A8"
                                    android:textSize="14sp"/>

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="18dp"
                            android:background="#263242"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Mantén al equipo en movimiento"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FITTRACK"
                                android:textColor="#2F7BFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ================= RESUMEN DEL GYM ================= -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resumen del gym"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rendimiento general de FitTrack"
                            android:textColor="#8D99A8"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/fondo_icono_azul"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:text="HOY"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- ================= FILA 1 ================= -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <!-- CLIENTES -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardClientes"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#151B26"
                        app:cardCornerRadius="22dp"
                        app:strokeColor="#263242"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/fondo_icono_azul"
                                android:padding="12dp"
                                android:src="@drawable/ic_people"
                                app:tint="#FFFFFF"/>

                            <Space
                                android:layout_width="1dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:id="@+id/tvTotalClientes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="48"
                                android:textColor="#FFFFFF"
                                android:textSize="30sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Atletas"
                                android:textColor="#8D99A8"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- RUTINAS -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRutinas"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#2F7BFF"
                        app:cardCornerRadius="22dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="#4C92FF"
                                android:padding="12dp"
                                android:src="@drawable/ic_routine"
                                app:tint="#FFFFFF"/>

                            <Space
                                android:layout_width="1dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:id="@+id/tvTotalRutinas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15"
                                android:textColor="#FFFFFF"
                                android:textSize="30sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rutinas"
                                android:textColor="#DCE8FF"
                                android:textSize="13sp"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ================= FILA 2 ================= -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- ENTRENADORES -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardEntrenadores"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#151B26"
                        app:cardCornerRadius="22dp"
                        app:strokeColor="#263242"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTotalEntrenadores"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="#FFFFFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Coaches"
                                android:textColor="#8D99A8"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- PROGRESO -->

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardProgreso"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#151B26"
                        app:cardCornerRadius="22dp"
                        app:strokeColor="#263242"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvProgresoPromedio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="78%"
                                android:textColor="#2F7BFF"
                                android:textSize="28sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Progreso"
                                android:textColor="#8D99A8"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ================= ACCIONES RÁPIDAS ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:text="¿Qué quieres hacer?"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Accede rápidamente a las herramientas del gimnasio"
                    android:textColor="#8D99A8"
                    android:textSize="13sp"/>

                <!-- MIS ATLETAS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnVerClientes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#151B26"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#263242"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/fondo_icono_azul"
                            android:padding="12dp"
                            android:src="@drawable/ic_people"
                            app:tint="#FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mis atletas"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Consulta clientes y su información"
                                android:textColor="#8D99A8"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#2F7BFF"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- RUTINAS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnVerRutinas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#151B26"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="5dp"
                    app:strokeColor="#263242"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/fondo_icono_azul"
                            android:padding="12dp"
                            android:src="@drawable/ic_routine"
                            app:tint="#FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Zona de entrenamiento"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Gestiona planes y rutinas de ejercicio"
                                android:textColor="#8D99A8"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#2F7BFF"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>