<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#151B26"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp"
    app:strokeColor="#263242"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <!-- Día -->

        <TextView
            android:id="@+id/tvDiaCalendario"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/fondo_icono_azul"
            android:gravity="center"
            android:text="LU"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Información -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreEntrenamientoCalendario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Push Day"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHorarioEntrenamientoCalendario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Lunes • 18:00"
                android:textColor="#8D99A8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDuracionEntrenamientoCalendario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="60 minutos"
                android:textColor="#2F7BFF"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Estado -->

        <TextView
            android:id="@+id/tvEstadoEntrenamientoCalendario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_chip_hoy"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="PENDIENTE"
            android:textColor="#2F7BFF"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>