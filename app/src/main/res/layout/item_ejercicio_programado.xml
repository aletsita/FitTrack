<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#E5EAE7"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="17dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNumeroEjercicio"
                android:layout_width="43dp"
                android:layout_height="43dp"
                android:background="@drawable/fondo_icono_verde"
                android:gravity="center"
                android:text="01"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreEjercicioProgramado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Press de banca"
                    android:textColor="#1F2933"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResumenEjercicioProgramado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="4 series · 10 repeticiones · 60 s"
                    android:textColor="#78847E"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvPesoEjercicioProgramado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="57dp"
            android:layout_marginTop="8dp"
            android:text="Peso: 60 kg"
            android:textColor="#238B57"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotasEjercicioProgramado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="57dp"
            android:layout_marginTop="5dp"
            android:text="Notas del ejercicio"
            android:textColor="#66756E"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="EDITAR"
                android:textColor="#238B57"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#E9F5EE"
                app:cornerRadius="13dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:text="ELIMINAR"
                android:textColor="#D95C5C"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#FCEEEE"
                app:cornerRadius="13dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>