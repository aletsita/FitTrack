<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#151B26"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp"
    app:strokeColor="#263242"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <!-- Icono -->

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/fondo_icono_azul"
            android:contentDescription="Rutina"
            android:padding="14dp"
            android:src="@drawable/ic_routine"
            app:tint="#FFFFFF"/>

        <!-- Información -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreRutina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Push Day"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDescripcionRutina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:maxLines="1"
                android:text="Pecho, hombro y tríceps"
                android:textColor="#8D99A8"
                android:textSize="13sp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDuracionRutina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 min"
                    android:textColor="#2F7BFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="•"
                    android:textColor="#4D5B6E"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvEjerciciosRutina"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="6 ejercicios"
                    android:textColor="#8D99A8"
                    android:textSize="13sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Flecha -->

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:contentDescription="Ver rutina"
            android:src="@drawable/ic_arrow_right"
            app:tint="#6FA7FF"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>