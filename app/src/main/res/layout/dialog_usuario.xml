<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#070B12"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvTituloDialogUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo usuario"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSubtituloDialogUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Registra un integrante del equipo FitTrack."
                android:textColor="#B7C0CD"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- FORMULARIO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre completo"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8D99A8"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- CORREO -->

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Correo electrónico"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreoUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8D99A8"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- CONTRASEÑA -->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPasswordUsuario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Contraseña"
                app:boxBackgroundColor="#151B26"
                app:boxStrokeColor="#2F7BFF"
                app:hintTextColor="#8D99A8"
                app:endIconMode="password_toggle"
                app:endIconTint="#2F7BFF"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPasswordUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ROL -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Rol del usuario"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <RadioGroup
                android:id="@+id/rgRolUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbAdministrador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="#2F7BFF"
                    android:text="Administrador"
                    android:textColor="#FFFFFF"/>

                <RadioButton
                    android:id="@+id/rbOperador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="#2F7BFF"
                    android:checked="true"
                    android:text="Operador"
                    android:textColor="#FFFFFF"/>

            </RadioGroup>

            <!-- SWITCH -->

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchUsuarioActivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:checked="true"
                android:text="Usuario activo"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                app:thumbTint="#2F7BFF"
                app:trackTint="#4A5A75"/>

            <ProgressBar
                android:id="@+id/progressDialogUsuario"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:indeterminateTint="#2F7BFF"
                android:visibility="gone"/>

            <!-- BOTÓN GUARDAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                android:text="Guardar usuario"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2F7BFF"
                app:cornerRadius="22dp"
                app:elevation="5dp"/>

            <!-- BOTÓN ELIMINAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:text="Eliminar usuario"
                android:textAllCaps="false"
                android:textColor="#FF6B81"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#151B26"
                app:cornerRadius="22dp"
                app:strokeColor="#FF6B81"
                app:strokeWidth="1dp"/>

            <!-- BOTÓN CANCELAR -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="12dp"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#2F7BFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#151B26"
                app:cornerRadius="22dp"
                app:strokeColor="#2F7BFF"
                app:strokeWidth="1dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>