<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F4F6F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ENCABEZADO DEL MODAL -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/tvTituloDialogUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo usuario"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtituloDialogUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Registra un integrante del equipo FitTrack."
                android:textColor="#DDEFE5"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre completo"
                app:boxStrokeColor="#238B57">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Correo electrónico"
                app:boxStrokeColor="#238B57">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreoUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutPasswordUsuario"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Contraseña"
                app:boxStrokeColor="#238B57"
                app:endIconMode="password_toggle"
                app:endIconTint="#238B57">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPasswordUsuarioDialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Rol del usuario"
                android:textColor="#1F2933"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgRolUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbAdministrador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="#238B57"
                    android:text="Administrador"
                    android:textColor="#1F2933" />

                <RadioButton
                    android:id="@+id/rbOperador"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="#238B57"
                    android:checked="true"
                    android:text="Operador"
                    android:textColor="#1F2933" />

            </RadioGroup>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchUsuarioActivo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:checked="true"
                android:text="Usuario activo"
                android:textColor="#1F2933"
                android:textSize="15sp"
                app:thumbTint="#238B57" />

            <ProgressBar
                android:id="@+id/progressDialogUsuario"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:indeterminateTint="#238B57"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:text="GUARDAR USUARIO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#238B57"
                app:cornerRadius="17dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="ELIMINAR USUARIO"
                android:textColor="#D95C5C"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="17dp"
                app:strokeColor="#E8B0B0"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarUsuarioDialog"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="CANCELAR"
                android:textColor="#1F2933"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="17dp"
                app:strokeColor="#DDE3E0"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>