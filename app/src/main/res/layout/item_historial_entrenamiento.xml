<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="11dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="19dp"
    app:cardElevation="2dp"
    app:strokeColor="#E7ECE9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="98dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/fondo_icono_verde"
            android:contentDescription="Entrenamiento"
            android:padding="12dp"
            android:src="@drawable/ic_fitness"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistorialNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Push Day"
                android:textColor="#1F2933"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistorialFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="15 de julio de 2026"
                android:textColor="#78847E"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvHistorialResumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="52 min • 4 ejercicios"
                android:textColor="#238B57"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Ver detalle"
            android:src="@drawable/ic_arrow_right"
            app:tint="#78847E" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>