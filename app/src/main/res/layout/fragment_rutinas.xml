<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- HEADER -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_encabezado_dashboard"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="32dp"
                android:paddingEnd="24dp"
                android:paddingBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.15"
                    android:text="ENTRENAMIENTO"
                    android:textColor="#2F7BFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Construye atletas"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Crea, consulta y administra planes de entrenamiento."
                    android:textColor="#B7C0CD"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- ================= RUTINA DESTACADA ================= -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRutinaDestacada"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#151B26"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeColor="#263242"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RUTINA DESTACADA"
                            android:textColor="#2F7BFF"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fondo_icono_azul"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="ACTIVA"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRutinaDestacadaNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="PUSH DAY"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvRutinaDestacadaDescripcion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Pecho • Hombro • Tríceps"
                        android:textColor="#8D99A8"
                        android:textSize="14sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerRutinaDestacada"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginTop="22dp"
                        android:text="Ver entrenamiento"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#2F7BFF"
                        app:cornerRadius="18dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ================= TÍTULO ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Todas las rutinas"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCantidadRutinas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="4 planes disponibles"
                        android:textColor="#8D99A8"
                        android:textSize="13sp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fondo_icono_azul"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="FITTRACK"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ================= LISTA ================= -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRutinas"
                android:layout_width="match_parent"
                android:layout_height="600dp"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_rutina"/>

            <!-- ================= TÍTULO ================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Todas las rutinas"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCantidadRutinas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="4 planes disponibles"
                        android:textColor="#8D99A8"
                        android:textSize="13sp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fondo_icono_azul"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="FITTRACK"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- ================= LISTA ================= -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRutinas"
                android:layout_width="match_parent"
                android:layout_height="600dp"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                tools:listitem="@layout/item_rutina"/>

        </LinearLayout>

    </ScrollView>

    <!-- ================= BOTÓN NUEVA RUTINA ================= -->

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnNuevaRutina"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="Nueva rutina"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="#2F7BFF"
        app:cornerRadius="30dp"
        app:icon="@drawable/ic_routine"
        app:iconPadding="10dp"
        app:iconTint="#FFFFFF"
        app:rippleColor="#4C92FF"/>

</FrameLayout>