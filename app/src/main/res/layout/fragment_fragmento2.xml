<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CATÁLOGO DE CLIENTES"
            android:textAlignment="center"
            android:textColor="#2E4053"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Datos del Cliente"
                    android:textColor="#3498DB"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="15dp"/>

                <EditText
                    android:id="@+id/etClave"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Clave"
                    android:padding="10dp"
                    android:inputType="number"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Nombre"
                    android:padding="10dp"
                    android:inputType="textPersonName"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etEdad"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Edad"
                    android:padding="10dp"
                    android:inputType="number"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etFechaNacimiento"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Fecha de nacimiento"
                    android:padding="10dp"
                    android:inputType="date"
                    android:background="@android:drawable/edit_text"/>

                <ProgressBar
                    android:id="@+id/progressClientes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnNuevo"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Nuevo"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3498DB"/>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Guardar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#27AE60"/>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnEliminar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Eliminar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E74C3C"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#5DADE2"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Clave"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="16dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Edad"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClientes"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="5dp"
            android:nestedScrollingEnabled="false"/>

        <TextView
            android:id="@+id/tvEmptyGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hay clientes guardados todavía"
            android:textColor="#888888"
            android:textAlignment="center"
            android:padding="20dp"
            android:visibility="gone"/>

    </LinearLayout>

</ScrollView>