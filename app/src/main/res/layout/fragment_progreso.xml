<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="105dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.15"
                android:text="PROGRESO"
                android:textColor="#2F7BFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cada minuto cuenta."
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Consulta tu objetivo, tiempo acumulado e historial."
                android:textColor="#B7C0CD"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- ================= OBJETIVO SEMANAL ================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardBackgroundColor="#151B26"
            app:cardCornerRadius="24dp"
            app:cardElevation="5dp"
            app:strokeColor="#263242"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OBJETIVO SEMANAL"
                        android:textColor="#2F7BFF"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfigurarObjetivo"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:text="Configurar"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#2F7BFF"
                        app:cornerRadius="16dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvPorcentajeSemanal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="42sp"
                    android:textStyle="bold"/>

                <ProgressBar
                    android:id="@+id/progressSemanal"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2F7BFF"
                    android:progressBackgroundTint="#263242"/>

                <TextView
                    android:id="@+id/tvResumenObjetivo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="0 min de 5 horas"
                    android:textColor="#8D99A8"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvResumenSesiones"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0 de 4 sesiones"
                    android:textColor="#2F7BFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
        <!-- ================= ESTADÍSTICAS ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal">

            <!-- ENTRENAMIENTOS -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#151B26"
                app:cardCornerRadius="22dp"
                app:strokeColor="#263242"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/fondo_icono_azul"
                        android:padding="12dp"
                        android:src="@drawable/ic_routine"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvTotalEntrenamientos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entrenamientos"
                        android:textColor="#8D99A8"
                        android:textSize="13sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- TIEMPO -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#2F7BFF"
                app:cardCornerRadius="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="#5B9BFF"
                        android:padding="12dp"
                        android:src="@drawable/time"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvTiempoAcumulado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="0 min"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiempo semanal"
                        android:textColor="#DCE8FF"
                        android:textSize="13sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ================= PLAN SEMANAL ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plan semanal"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#151B26"
                app:cardCornerRadius="22dp"
                app:strokeColor="#263242"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvPlanSemanal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="Todavía no has configurado un plan."
                    android:textColor="#8D99A8"
                    android:textSize="14sp"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ================= HISTORIAL ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrenamientos recientes"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSinEntrenamientos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/edittext_dark"
                android:gravity="center"
                android:padding="24dp"
                android:text="Aún no has finalizado ningún entrenamiento."
                android:textColor="#8D99A8"
                android:textSize="14sp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistorialEntrenamientos"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="18dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="10dp"
                android:visibility="gone"
                tools:listitem="@layout/item_historial_entrenamiento"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>