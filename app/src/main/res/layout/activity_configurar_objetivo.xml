<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="35dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="PROGRESO"
                android:textColor="#9FD7B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Objetivo semanal."
                android:textColor="#FFFFFF"
                android:textSize="29sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Configura el tiempo y las rutinas que deseas completar."
                android:textColor="#DDEFE5"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meta de entrenamiento"
                android:textColor="#1F2933"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7dp"
                    android:layout_weight="1"
                    android:hint="Horas"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxStrokeColor="#238B57"
                    app:suffixText="h">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHorasObjetivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:layout_weight="1"
                    android:hint="Sesiones"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxStrokeColor="#238B57">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSesionesObjetivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="Días de entrenamiento"
                android:textColor="#1F2933"
                android:textSize="18sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbLunes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Lunes" />

            <CheckBox
                android:id="@+id/cbMartes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Martes" />

            <CheckBox
                android:id="@+id/cbMiercoles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Miércoles" />

            <CheckBox
                android:id="@+id/cbJueves"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Jueves" />

            <CheckBox
                android:id="@+id/cbViernes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Viernes" />

            <CheckBox
                android:id="@+id/cbSabado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Sábado" />

            <CheckBox
                android:id="@+id/cbDomingo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Domingo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="Rutinas planeadas"
                android:textColor="#1F2933"
                android:textSize="18sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbPushDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Push Day" />

            <CheckBox
                android:id="@+id/cbPullDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Pull Day" />

            <CheckBox
                android:id="@+id/cbLegDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Leg Day" />

            <CheckBox
                android:id="@+id/cbFullBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="#238B57"
                android:text="Full Body" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarObjetivo"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="25dp"
                android:text="GUARDAR OBJETIVO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#238B57"
                app:cornerRadius="17dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarObjetivo"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:text="CANCELAR"
                android:textColor="#1F2933"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="17dp"
                app:strokeColor="#DDE3E0"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>