<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Fragmento3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/TextoF3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMPRAS\n\nEsta es la pantalla de compras, que se encuentra adentro del fragmento 3"
            android:textAlignment="center"
            android:textColor="#2E4053"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="4dp" />

        <Button
            android:id="@+id/btnBotonCompras"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:text="Crear Compra"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3498DB" />

    </LinearLayout>

</FrameLayout>