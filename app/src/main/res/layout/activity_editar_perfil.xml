<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="35dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MI CUENTA"
                android:textColor="#9FD7B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Editar perfil."
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/etEditarNombrePerfil"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#FFFFFF"
                android:hint="Nombre completo"
                android:padding="15dp" />

            <EditText
                android:id="@+id/etEditarPesoPerfil"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="14dp"
                android:background="#FFFFFF"
                android:hint="Peso en kg"
                android:inputType="numberDecimal"
                android:padding="15dp" />

            <EditText
                android:id="@+id/etEditarAlturaPerfil"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="14dp"
                android:background="#FFFFFF"
                android:hint="Altura en metros"
                android:inputType="numberDecimal"
                android:padding="15dp" />

            <EditText
                android:id="@+id/etEditarObjetivoPerfil"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="14dp"
                android:background="#FFFFFF"
                android:gravity="top"
                android:hint="Objetivo personal"
                android:inputType="textMultiLine"
                android:padding="15dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="24dp"
                android:text="GUARDAR CAMBIOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#238B57"
                app:cornerRadius="17dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarPerfil"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:text="CANCELAR"
                android:textColor="#1F2933"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="17dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>