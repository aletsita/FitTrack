<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="30dp">

        <!-- ENCABEZADO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/fondo_encabezado_dashboard"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.15"
                android:text="FITTRACK TRAINING"
                android:textColor="#2F7BFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDetalleNombreRutina"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PUSH DAY"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDetalleDescripcionRutina"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Pecho, hombro y tríceps"
                android:textColor="#B7C0CD"
                android:textSize="15sp"/>

        </LinearLayout>

        <!-- INFORMACIÓN -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="-30dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#151B26"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeColor="#263242"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="22dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NIVEL"
                        android:textColor="#8B97A8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDetalleNivelRutina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="Intermedio"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURACIÓN"
                        android:textColor="#8B97A8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDetalleDuracionRutina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="60 min"
                        android:textColor="#2F7BFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EJERCICIOS"
                        android:textColor="#8B97A8"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDetalleEjerciciosRutina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="6 ejercicios"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- EJERCICIOS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="30dp"
            android:text="Plan de entrenamiento"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="5dp"
            android:text="Ejercicios incluidos en esta rutina"
            android:textColor="#9AA5B5"
            android:textSize="14sp"/>

        <!-- EJERCICIO 1 -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#151B26"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="#263242"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="22dp"
                android:text="01   Press de banca&#10;       4 series • 10 repeticiones"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- EJERCICIO 2 -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#151B26"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="#263242"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="22dp"
                android:text="02   Press militar&#10;       4 series • 12 repeticiones"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- EJERCICIO 3 -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#151B26"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="#263242"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="22dp"
                android:text="03   Fondos de tríceps&#10;       3 series • 12 repeticiones"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÓN PRINCIPAL -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmpezarEntrenamiento"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="18dp"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="18dp"
            android:text="EMPEZAR ENTRENAMIENTO"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#2F7BFF"
            app:cornerRadius="22dp"
            app:elevation="5dp"
            app:icon="@drawable/ic_fitness"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF"/>

        <!-- BOTÓN SECUNDARIO -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolverRutinas"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginStart="18dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="18dp"
            android:text="Volver a rutinas"
            android:textAllCaps="false"
            android:textColor="#2F7BFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#151B26"
            app:cornerRadius="22dp"
            app:strokeColor="#2F7BFF"
            app:strokeWidth="1dp"/>

    </LinearLayout>

</ScrollView>