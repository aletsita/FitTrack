<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Proyecto"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ui.usuarios.nuevo.NuevoUsuarioActivity"
            android:exported="false" />

        <activity
            android:name=".ui.entrenamiento.EntrenamientoActivoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.rutinas.nueva.NuevaRutinaActivity"
            android:exported="false" />

        <activity
            android:name=".ui.rutinas.detalle.DetalleRutinaActivity"
            android:exported="false" />

        <activity
            android:name=".Principal"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>

                <action
                    android:name="android.intent.action.MAIN" />

                <category
                    android:name="android.intent.category.LAUNCHER" />

            </intent-filter>

        </activity>

        <activity
            android:name=".ui.progreso.objetivo.ConfigurarObjetivoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.progreso.detalle.DetalleSesionActivity"
            android:exported="false" />

        <activity
            android:name=".ui.calendario.programar.ProgramarEntrenamientoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.perfil.editar.EditarPerfilActivity"
            android:exported="false" />

    </application>

</manifest>